# ─────────────────────────────────────────────────────────────
# LLM TRADING SYSTEM — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=trading_db

# ── Application ───────────────────────────────────────────────
SECRET_KEY=generate_a_64_char_random_string_here
APP_ENV=production

# ── Anthropic / Claude ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SMTP (Email Alerts) ───────────────────────────────────────
SMTP_HOST=server.minpay.in
SMTP_PORT=587
SMTP_USER=info@minpay.in
SMTP_PASS=your_smtp_password
ALERT_EMAIL_FROM=info@minpay.in
ALERT_EMAIL_TO=your@email.com

# ── Broker (currently in paper mode — fill when ready) ────────
BROKER_TYPE=paper
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REQUEST_TOKEN=
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://trade.sanskarsaraf.in/api
NEXT_PUBLIC_WS_URL=wss://trade.sanskarsaraf.in/ws
